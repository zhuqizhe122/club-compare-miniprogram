.club-card {
  margin-bottom: 22rpx;
  padding: 28rpx;
  border: 1px solid #d8e2df;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 10rpx 30rpx rgba(20, 47, 43, 0.07);
}

.club-card.selected {
  border-color: #21a58f;
  box-shadow: 0 0 0 3rpx #d9f1eb;
}

.topline,
.identity,
.meta,
.actions {
  display: flex;
  align-items: center;
}

.topline {
  justify-content: space-between;
  gap: 20rpx;
}

.identity {
  min-width: 0;
  gap: 14rpx;
}

.rank {
  color: #087c6b;
  font-weight: 800;
}

.name {
  font-size: 32rpx;
  font-weight: 750;
}

.score-block {
  flex: 0 0 90rpx;
  text-align: right;
}

.score {
  display: block;
  color: #087c6b;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1;
}

.score-label {
  color: #71827e;
  font-size: 19rpx;
}

.tagline {
  margin-top: 14rpx;
  color: #58706c;
  font-size: 24rpx;
}

.meta {
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.chip {
  padding: 6rpx 13rpx;
  border-radius: 999rpx;
  color: #0b4e45;
  background: #e8f4f0;
  font-size: 21rpx;
}

.evidence-copy {
  color: #8a7560;
  font-size: 20rpx;
}

.reasons {
  margin-top: 20rpx;
  padding: 17rpx 20rpx;
  border-radius: 16rpx;
  background: #f5f8f7;
}

.reason,
.caution {
  display: flex;
  gap: 12rpx;
  margin: 7rpx 0;
  color: #38554f;
  font-size: 23rpx;
}

.reason-mark {
  color: #087c6b;
  font-weight: 800;
}

.caution {
  color: #8d581d;
}

.caution-mark {
  font-weight: 800;
}

.actions {
  gap: 16rpx;
  margin-top: 22rpx;
}

.actions button {
  flex: 1;
  margin: 0;
  border-radius: 14rpx;
  font-size: 24rpx;
  line-height: 70rpx;
}

button::after {
  border: 0;
}

.detail {
  color: #0b4e45;
  background: #eef4f2;
}

.select {
  color: #fff;
  background: #087c6b;
}

.select.active {
  color: #087c6b;
  background: #dff2ed;
}
