.club-card {
  margin-bottom: 22rpx;
  padding: 26rpx;
  border: 1px solid var(--line, #d8e2df);
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 10rpx 28rpx rgba(20, 47, 43, 0.06);
}

.club-card.selected {
  border-color: #21a58f;
  box-shadow: 0 0 0 3rpx #d9f1eb;
}

.card-head {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
}

.thumb {
  flex: 0 0 88rpx;
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  color: #0b4e45;
  background:
    linear-gradient(145deg, rgba(8, 124, 107, 0.16), rgba(8, 124, 107, 0.04)),
    #e8f4f0;
}

.thumb-mark {
  font-size: 34rpx;
  font-weight: 800;
}

.head-main {
  flex: 1;
  min-width: 0;
}

.topline,
.identity,
.meta,
.actions {
  display: flex;
  align-items: center;
}

.topline {
  justify-content: space-between;
  gap: 16rpx;
}

.identity {
  min-width: 0;
  gap: 10rpx;
  flex: 1;
}

.rank {
  flex-shrink: 0;
  color: #087c6b;
  font-weight: 800;
  font-size: 26rpx;
}

.name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 750;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.score-block {
  flex: 0 0 auto;
  min-width: 84rpx;
  padding: 10rpx 14rpx;
  text-align: center;
  border-radius: 18rpx;
  background: #f0f8f5;
}

.score {
  display: block;
  color: #087c6b;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1;
}

.score-label {
  display: block;
  margin-top: 4rpx;
  color: #71827e;
  font-size: 18rpx;
}

.tagline {
  margin-top: 10rpx;
  color: #58706c;
  font-size: 24rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.meta {
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.chip,
.verify-chip {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.chip {
  color: #0b4e45;
  background: #e8f4f0;
}

.verify-chip {
  color: #74501d;
  background: #fff4df;
  font-weight: 650;
}

.reasons {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: #f5f8f7;
}

.reason,
.caution,
.note-row {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
}

.reason + .reason,
.reason + .caution,
.caution + .caution,
.note-row + .note-row {
  margin-top: 10rpx;
}

.reason,
.caution {
  color: #38554f;
  font-size: 22rpx;
  line-height: 1.45;
}

.reason-mark,
.caution-mark {
  flex: 0 0 24rpx;
  font-weight: 800;
}

.reason-mark {
  color: #087c6b;
}

.caution {
  color: #8d581d;
}

.caution-mark {
  color: #c07a22;
}

.reason-text,
.note-text {
  flex: 1;
  min-width: 0;
}

.notes {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1px dashed #d8e2df;
}

.note-row {
  color: #546b67;
  font-size: 22rpx;
  line-height: 1.5;
}

.note-label {
  flex: 0 0 58rpx;
  height: 34rpx;
  border-radius: 8rpx;
  text-align: center;
  line-height: 34rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.cost-label {
  color: #75501f;
  background: #fff0d4;
}

.unknown-label {
  color: #803f38;
  background: #fae7e4;
}

.actions {
  gap: 14rpx;
  margin-top: 20rpx;
}

.actions button {
  flex: 1;
  margin: 0;
  padding: 0 12rpx;
  border-radius: 16rpx;
  font-size: 25rpx;
  font-weight: 650;
  line-height: 72rpx;
  min-height: 72rpx;
  white-space: nowrap;
}

button::after {
  border: 0;
}

.detail {
  color: #0b4e45;
  background: #eef4f2;
}

.select {
  color: #fff;
  background: #087c6b;
}

.select.active {
  color: #087c6b;
  background: #dff2ed;
}
