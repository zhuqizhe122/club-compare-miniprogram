<view class="page">
  <view class="title">为你推荐的社团</view>
  <view class="lead">含推荐理由与简介。勾选不多于 4 个进行比较（已选 {{selectedCount}}/4）。点名称可看详情。</view>

  <view class="hint" wx:if="{{error}}">{{error}}</view>

  <view class="rec-item {{item.checked ? 'checked' : ''}}" wx:for="{{items}}" wx:key="id">
    <view class="rec-row">
      <view class="check" data-id="{{item.id}}" bindtap="onToggle">
        {{item.checked ? '✓' : ''}}
      </view>
      <view class="rec-body">
        <view class="rec-name" data-id="{{item.id}}" bindtap="onOpenDetail">{{item.name}}</view>
        <view class="rec-tagline">{{item.tagline}}</view>
        <view class="rec-reason">{{item.reason}}</view>
        <view class="link" data-id="{{item.id}}" bindtap="onOpenDetail">查看详情 →</view>
      </view>
    </view>
  </view>

  <button class="btn-primary" bindtap="onCompare" wx:if="{{items.length}}">对比已选社团</button>
  <button class="btn-secondary" bindtap="onQuestions" wx:if="{{items.length}}">选择好了，给我提问建议</button>
</view>
