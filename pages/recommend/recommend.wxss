.header {
  padding-top: 8rpx;
  margin-bottom: 8rpx;
}

.header .title {
  font-size: 42rpx;
}

.header .lead {
  margin-bottom: 18rpx;
  font-size: 25rpx;
  line-height: 1.6;
}

.grade-note {
  margin: 0 0 18rpx;
  padding: 18rpx 20rpx;
  color: #765222;
  border: 1px solid #efd8af;
  border-radius: 16rpx;
  background: var(--warn-bg);
  font-size: 22rpx;
  line-height: 1.55;
}

.edit-answer {
  width: auto;
  margin: 0 0 18rpx;
  padding: 0 24rpx;
  color: var(--brand);
  border: 1px solid var(--line);
  border-radius: 999rpx;
  background: #fff;
  font-size: 24rpx;
  line-height: 64rpx;
  min-height: 64rpx;
}

.recommend-list {
  display: block;
}

.empty {
  margin-top: 120rpx;
  padding: 40rpx 30rpx;
  text-align: center;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 750;
}

.empty-copy {
  margin-top: 16rpx;
  color: var(--ink-soft);
  font-size: 24rpx;
}
