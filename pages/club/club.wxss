.hero,
.detail-card,
.bar-card,
.evidence-card {
  padding: 28rpx;
  margin-bottom: 28rpx;
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.hero .title {
  margin-top: 8rpx;
  font-size: 42rpx;
}

.verify-chip {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  color: var(--brand-dark);
  background: var(--mint);
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.gallery {
  margin: 0 0 34rpx;
  white-space: nowrap;
}

.gallery-track {
  display: inline-flex;
  gap: 16rpx;
  padding-bottom: 4rpx;
}

.gallery-item {
  width: 280rpx;
  flex-shrink: 0;
}

.gallery-image,
.gallery-placeholder {
  width: 280rpx;
  height: 200rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.gallery-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: #6f8f88;
  background:
    linear-gradient(135deg, rgba(8, 124, 107, 0.08), rgba(8, 124, 107, 0.02)),
    repeating-linear-gradient(
      -45deg,
      #e8f1ee,
      #e8f1ee 12rpx,
      #f4faf8 12rpx,
      #f4faf8 24rpx
    );
  border: 1px dashed var(--line-strong);
}

.gallery-placeholder-mark {
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.gallery-placeholder-copy {
  font-size: 22rpx;
}

.gallery-caption {
  margin-top: 12rpx;
  color: var(--ink-soft);
  font-size: 22rpx;
  white-space: normal;
}

.fact {
  display: flex;
  gap: 24rpx;
  padding: 20rpx 0;
  border-bottom: 1px solid var(--line);
  color: var(--ink-soft);
  font-size: 25rpx;
}

.fact:last-child {
  border-bottom: 0;
}

.fact-label {
  flex: 0 0 150rpx;
  color: var(--ink);
  font-weight: 650;
}

.source-title {
  margin-bottom: 10rpx;
  font-weight: 700;
}

.missing {
  text-align: center;
}
