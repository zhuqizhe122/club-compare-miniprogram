<view class="page" wx:if="{{club}}">
  <view class="hero card">
    <view class="hero-top">
      <view>
        <view class="eyebrow">{{club.categoryLabel}}</view>
        <view class="title">{{club.name}}</view>
      </view>
      <view class="verify-chip">待现场核实</view>
    </view>
    <view class="lead">{{club.tagline}}</view>
    <view class="tag-row">
      <text wx:for="{{club.tags}}" wx:key="*this" class="chip">{{item}}</text>
    </view>
    <button class="btn-primary" bindtap="onToggleSelection">{{selected ? '移除候选' : '加入候选'}}</button>
  </view>

  <view class="section-title">活动图片</view>
  <scroll-view class="gallery" scroll-x show-scrollbar="{{false}}">
    <view class="gallery-track">
      <view class="gallery-item" wx:for="{{club.images}}" wx:key="caption">
        <image wx:if="{{item.src && !item.isPlaceholder}}" class="gallery-image" src="{{item.src}}" mode="aspectFill" />
        <view wx:else class="gallery-placeholder">
          <text class="gallery-placeholder-mark">IMG</text>
          <text class="gallery-placeholder-copy">图片占位</text>
        </view>
        <view class="gallery-caption">{{item.caption}}</view>
      </view>
    </view>
  </scroll-view>

  <view class="section-title">时间与参与</view>
  <view class="detail-card card">
    <view class="fact"><text class="fact-label">普通周</text><text>{{club.normalHours}}</text></view>
    <view class="fact"><text class="fact-label">高峰周</text><text>{{club.peakHours}}</text></view>
    <view class="fact"><text class="fact-label">常见时段</text><text>{{club.slotsText}}</text></view>
    <view class="fact"><text class="fact-label">活动频率</text><text>{{club.frequency}}</text></view>
    <view class="fact"><text class="fact-label">活动形式</text><text>{{club.modesText}}</text></view>
    <view class="fact"><text class="fact-label">成长收益</text><text>{{club.benefitsText}}</text></view>
    <view class="fact"><text class="fact-label">考勤弹性</text><text>{{club.flexibilityText}}；{{club.attendanceText}}</text></view>
    <view class="fact"><text class="fact-label">投入模式</text><text>{{club.commitmentText}}</text></view>
  </view>

  <view class="section-title">加入条件与成本</view>
  <view class="detail-card card">
    <view class="fact"><text class="fact-label">入门方式</text><text>{{club.entryText}}</text></view>
    <view class="fact"><text class="fact-label">是否选拔</text><text>{{club.selectionText}}</text></view>
    <view class="fact"><text class="fact-label">费用估计</text><text>{{club.costText}}</text></view>
    <view class="fact"><text class="fact-label">器材要求</text><text>{{club.equipmentText}}</text></view>
    <view class="fact"><text class="fact-label">校外活动</text><text>{{club.offCampusText}}</text></view>
  </view>

  <view class="section-title">五维体验条</view>
  <view class="bar-card card">
    <dimension-bar wx:for="{{club.bars}}" wx:key="label" label="{{item.label}}" value="{{item.value}}" note="{{item.note}}" />
  </view>

  <view class="section-title">资料说明</view>
  <view class="evidence-card card">
    <view class="source-title">演示资料，请现场确认</view>
    <view class="section-copy">时间、费用、选拔和活动安排以本学期招新现场与社团负责人为准；本页内容仅供缩小候选范围。</view>
  </view>
</view>

<view class="page missing" wx:else>
  <view class="title">未找到该社团</view>
  <view class="lead">链接中的社团编号无效或资料已移除。</view>
  <button class="btn-primary" bindtap="onBackLibrary">返回社团库</button>
</view>
