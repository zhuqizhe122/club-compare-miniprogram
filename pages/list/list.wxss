.club-list {
  margin-top: 16rpx;
}

.club-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: #fff;
  border-radius: 8rpx;
  border: 1px solid #e5e5e5;
}

.club-item.checked {
  border-color: #1a1a1a;
}

.club-name {
  font-weight: 600;
  font-size: 30rpx;
}

.club-tagline {
  color: #666;
  font-size: 24rpx;
  margin-top: 6rpx;
}
