<view class="page">
  <view class="title">选择要比较的社团</view>
  <view class="lead">请勾选 2–3 个（已选 {{selectedIds.length}} / 3）</view>

  <checkbox-group bindchange="onCheckChange">
    <label
      class="club-item {{item.checked ? 'checked' : ''}}"
      wx:for="{{clubs}}"
      wx:key="id"
    >
      <checkbox
        value="{{item.id}}"
        checked="{{item.checked}}"
        disabled="{{!item.checked && selectedIds.length >= 3}}"
      />
      <view class="club-text">
        <view class="club-name">{{item.name}}</view>
        <view class="club-tagline">{{item.tagline}}</view>
      </view>
    </label>
  </checkbox-group>

  <view class="hint" wx:if="{{error}}">{{error}}</view>
  <view class="hint" wx:elif="{{selectedIds.length >= 3}}">已选满 3 个；取消某一项后才能再选其他</view>

  <button class="btn-primary" bindtap="onCompare" disabled="{{!clubs.length}}">生成对照表</button>
</view>
