.guard {
  padding: 28rpx;
  background: var(--warn-bg);
  border-color: #efc98f;
}

.guard-title {
  color: #754812;
  font-size: 30rpx;
  font-weight: 700;
}

.guard-copy {
  margin-top: 10rpx;
  color: #765f43;
  font-size: 24rpx;
}

.option {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 28rpx 26rpx;
  margin-bottom: 16rpx;
  transition: border-color 0.15s ease, background 0.15s ease;
}

.option.selected {
  background: var(--mint);
  border-color: var(--brand);
  box-shadow: 0 0 0 3rpx rgba(8, 124, 107, 0.12);
}

.option-label {
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.35;
}

.option-note {
  margin-top: 8rpx;
  color: var(--ink-soft);
  font-size: 22rpx;
  line-height: 1.45;
}

.error-hint {
  color: var(--danger);
  font-weight: 650;
}

.action-stack {
  margin-top: 18rpx;
}

.confirm-btn {
  font-size: 28rpx;
  letter-spacing: 0;
}

.confirm-box {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.confirm-kicker,
.expectation-kicker {
  color: var(--brand);
  font-size: 21rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.confirm-text {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.screenshot-hint {
  margin: 34rpx 0 14rpx;
  color: var(--ink-soft);
  text-align: center;
  font-size: 22rpx;
}

.expectation-card {
  padding: 30rpx;
  margin-bottom: 18rpx;
  color: #eaf8f4;
  background: linear-gradient(145deg, #123c36, #0b6559);
  border-radius: 26rpx;
  box-shadow: 0 14rpx 34rpx rgba(18, 60, 54, 0.2);
}

.expectation-card.none-card {
  background: linear-gradient(145deg, #3b4341, #586865);
}

.expectation-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding-bottom: 24rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.18);
}

.expectation-kicker {
  color: #9fd9cf;
}

.expectation-name {
  margin-top: 8rpx;
  color: #fff;
  font-size: 34rpx;
  font-weight: 800;
}

.expectation-card .status {
  color: #ffe2b9;
  background: rgba(255, 235, 204, 0.12);
}

.score-strip {
  padding: 14rpx 16rpx;
  margin-top: 20rpx;
  color: #d9f3ed;
  background: rgba(255, 255, 255, 0.09);
  border-radius: 14rpx;
  font-size: 22rpx;
  font-variant-numeric: tabular-nums;
}

.card-section {
  padding-top: 22rpx;
  margin-top: 22rpx;
  border-top: 1px solid rgba(255, 255, 255, 0.13);
}

.card-section-title {
  color: #fff;
  font-size: 23rpx;
  font-weight: 700;
}

.expectation-line {
  display: flex;
  gap: 14rpx;
  margin-top: 20rpx;
  font-size: 24rpx;
}

.check {
  color: #8fe1d2;
  font-weight: 800;
}

.cost-mark,
.unknown-mark {
  display: inline-block;
  flex: 0 0 28rpx;
  width: 28rpx;
  height: 28rpx;
  margin-top: 3rpx;
  color: #173f39;
  background: #ffd494;
  border-radius: 50%;
  text-align: center;
  line-height: 28rpx;
  font-size: 19rpx;
  font-weight: 800;
}

.unknown-mark {
  background: #cad9d6;
}

.expectation-reminder {
  margin-top: 24rpx;
  padding-top: 20rpx;
  color: #b9d7d1;
  border-top: 1px solid rgba(255, 255, 255, 0.13);
  font-size: 21rpx;
}

.questions {
  padding: 28rpx;
  margin-top: 30rpx;
}

.question {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 20rpx 0;
  border-top: 1px solid var(--line);
}

.question-number {
  flex: 0 0 40rpx;
  width: 40rpx;
  height: 40rpx;
  color: #fff;
  background: var(--brand);
  border-radius: 50%;
  text-align: center;
  line-height: 40rpx;
  font-size: 21rpx;
}

.question-main {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
}

.question-source {
  display: inline-flex;
  padding: 4rpx 10rpx;
  margin-top: 8rpx;
  color: var(--warn);
  background: #fff4df;
  border-radius: 999rpx;
  font-size: 19rpx;
}

.review {
  padding: 28rpx;
  margin-top: 22rpx;
}

.review-item {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  padding: 16rpx 0;
  border-top: 1px solid var(--line);
  color: #36534e;
  font-size: 24rpx;
}

.review-box {
  flex: 0 0 30rpx;
  width: 30rpx;
  height: 30rpx;
  margin-top: 3rpx;
  border: 2px solid var(--brand);
  border-radius: 8rpx;
  box-sizing: border-box;
}

.evidence-notice {
  padding: 24rpx;
  margin-top: 22rpx;
  color: #74501d;
  background: #fff7e9;
  border: 1px solid #efd7af;
  border-radius: 20rpx;
  font-size: 23rpx;
}

.evidence-notice-title {
  margin-bottom: 8rpx;
  font-weight: 800;
}

.exit-box {
  padding: 28rpx;
  margin-top: 22rpx;
  background: #fff7e9;
  border-radius: 20rpx;
  border: 1px solid #f0d8b2;
}

.exit-title {
  color: #754812;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.exit-body {
  color: #765f43;
  font-size: 24rpx;
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 26rpx;
}

.actions button {
  flex: 1;
  margin-top: 0;
}

.detail-panel {
  margin-top: 36rpx;
}

.detail-lead {
  margin: -4rpx 0 22rpx;
}

.detail-hero {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.detail-hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.detail-name {
  margin-top: 8rpx;
  font-size: 36rpx;
  font-weight: 800;
}

.detail-tagline {
  margin-top: 14rpx;
  color: var(--ink-soft);
  font-size: 25rpx;
}

.verify-chip {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  color: var(--brand-dark);
  background: var(--mint);
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.section-title.soft {
  margin-top: 8rpx;
  font-size: 28rpx;
}

.gallery {
  margin: 0 0 28rpx;
  white-space: nowrap;
}

.gallery-track {
  display: inline-flex;
  gap: 16rpx;
}

.gallery-item {
  width: 260rpx;
  flex-shrink: 0;
}

.gallery-image,
.gallery-placeholder {
  width: 260rpx;
  height: 180rpx;
  border-radius: 18rpx;
  overflow: hidden;
}

.gallery-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: #6f8f88;
  background:
    linear-gradient(135deg, rgba(8, 124, 107, 0.08), rgba(8, 124, 107, 0.02)),
    repeating-linear-gradient(
      -45deg,
      #e8f1ee,
      #e8f1ee 12rpx,
      #f4faf8 12rpx,
      #f4faf8 24rpx
    );
  border: 1px dashed var(--line-strong);
}

.gallery-placeholder-mark {
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.gallery-placeholder-copy {
  font-size: 20rpx;
}

.gallery-caption {
  margin-top: 10rpx;
  color: var(--ink-soft);
  font-size: 21rpx;
  white-space: normal;
}

.detail-card {
  padding: 8rpx 28rpx;
  margin-bottom: 24rpx;
}

.fact {
  display: flex;
  gap: 24rpx;
  padding: 18rpx 0;
  border-bottom: 1px solid var(--line);
  color: var(--ink-soft);
  font-size: 24rpx;
}

.fact:last-child {
  border-bottom: 0;
}

.fact-label {
  flex: 0 0 140rpx;
  color: var(--ink);
  font-weight: 650;
}
