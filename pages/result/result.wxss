.option {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 26rpx;
  margin-bottom: 16rpx;
}

.option.selected {
  background: var(--mint);
  border-color: var(--brand);
}

.option-label {
  font-size: 28rpx;
  font-weight: 700;
}

.option-note {
  margin-top: 6rpx;
  color: var(--ink-soft);
  font-size: 22rpx;
}

.confirm-box {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.confirm-kicker,
.expectation-kicker {
  color: var(--brand);
  font-size: 21rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.confirm-text {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.screenshot-hint {
  margin: 34rpx 0 14rpx;
  color: var(--ink-soft);
  text-align: center;
  font-size: 22rpx;
}

.expectation-card {
  padding: 30rpx;
  margin-bottom: 18rpx;
  color: #eaf8f4;
  background: linear-gradient(145deg, #123c36, #0b6559);
  border-radius: 26rpx;
  box-shadow: 0 14rpx 34rpx rgba(18, 60, 54, 0.2);
}

.expectation-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding-bottom: 24rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.18);
}

.expectation-kicker {
  color: #9fd9cf;
}

.expectation-name {
  margin-top: 8rpx;
  color: #fff;
  font-size: 34rpx;
  font-weight: 800;
}

.expectation-card .status {
  color: #ffe2b9;
  background: rgba(255, 235, 204, 0.12);
}

.expectation-line {
  display: flex;
  gap: 14rpx;
  margin-top: 20rpx;
  font-size: 24rpx;
}

.check {
  color: #8fe1d2;
  font-weight: 800;
}

.expectation-reminder {
  margin-top: 24rpx;
  padding-top: 20rpx;
  color: #b9d7d1;
  border-top: 1px solid rgba(255, 255, 255, 0.13);
  font-size: 21rpx;
}

.questions {
  padding: 28rpx;
  margin-top: 30rpx;
}

.question {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 20rpx 0;
  border-top: 1px solid var(--line);
}

.question-number {
  flex: 0 0 40rpx;
  width: 40rpx;
  height: 40rpx;
  color: #fff;
  background: var(--brand);
  border-radius: 50%;
  text-align: center;
  line-height: 40rpx;
  font-size: 21rpx;
}

.exit-box {
  padding: 28rpx;
  margin-top: 22rpx;
  background: #fff7e9;
  border-radius: 20rpx;
  border: 1px solid #f0d8b2;
}

.exit-title {
  color: #754812;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.exit-body {
  color: #765f43;
  font-size: 24rpx;
}
