.section {
  margin-bottom: 28rpx;
}

.section-title {
  font-weight: 600;
  font-size: 28rpx;
  margin-bottom: 12rpx;
}

.pick-hint {
  font-size: 22rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.mini-name {
  font-size: 26rpx;
  color: #444;
  margin-bottom: 4rpx;
}

.option {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
  background: #fff;
  border-radius: 8rpx;
  border: 1px solid #e5e5e5;
}

.option-text {
  flex: 1;
  min-width: 0;
}

.option-label {
  font-weight: 600;
  font-size: 28rpx;
}

.option-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #666;
}

.confirm-box {
  padding: 24rpx;
  background: #fff;
  border-radius: 8rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.club-card {
  padding: 24rpx;
  background: #fff;
  border: 1px solid #e5e5e5;
  border-radius: 8rpx;
}

.club-name {
  font-weight: 600;
  font-size: 30rpx;
}

.club-tagline {
  color: #666;
  font-size: 24rpx;
  margin: 6rpx 0 12rpx;
}

.meta {
  font-size: 24rpx;
  color: #333;
  line-height: 1.45;
  margin-bottom: 4rpx;
}

.link {
  margin-top: 12rpx;
  font-size: 24rpx;
  text-decoration: underline;
}

.empty-tip {
  font-size: 26rpx;
  color: #555;
  line-height: 1.45;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.ask-box {
  padding: 24rpx;
  background: #fff;
  border: 1px solid #e5e5e5;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
}

.ask-title {
  font-weight: 600;
  margin-bottom: 16rpx;
}

.ask-item {
  display: flex;
  gap: 12rpx;
  margin-bottom: 14rpx;
  font-size: 26rpx;
  line-height: 1.45;
}

.ask-index {
  color: #888;
  flex-shrink: 0;
}

.exit-box {
  padding: 24rpx;
  background: #fff8e8;
  border: 1px solid #f0e0b8;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #444;
  margin-bottom: 16rpx;
}
