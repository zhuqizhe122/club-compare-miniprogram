.option {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
  background: #fff;
  border-radius: 8rpx;
  border: 1px solid #e5e5e5;
}

.confirm-box {
  padding: 28rpx;
  background: #fff;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
}

.confirm-text {
  font-size: 30rpx;
  font-weight: 600;
}

.exit-box {
  padding: 28rpx;
  background: #fff8e8;
  border-radius: 8rpx;
  border: 1px solid #f0e0b8;
}

.exit-title {
  font-weight: 600;
  margin-bottom: 12rpx;
}

.exit-body {
  color: #444;
  font-size: 26rpx;
}
