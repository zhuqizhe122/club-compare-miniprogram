<view class="page">
  <view class="eyebrow">当前结论</view>
  <view class="title">{{confirmed ? '把倾向变成可检查的预期' : '此刻，你愿意倾向哪一种选择？'}}</view>
  <view class="lead" wx:if="{{!confirmed && !guardMessage}}">倾向不是报名，也不是系统替你决定。若没有候选值得接受其代价，可以选择“先都不加”。</view>

  <view class="guard card" wx:if="{{guardMessage}}">
    <view class="guard-title">暂时不能形成结果</view>
    <view class="guard-copy">{{guardMessage}}</view>
    <button class="btn-primary" bindtap="onAdjust">返回比较</button>
  </view>

  <block wx:elif="{{!confirmed}}">
    <radio-group bindchange="onTendencyChange">
      <label
        class="option card {{tendency === item.value ? 'selected' : ''}}"
        wx:for="{{options}}"
        wx:key="value"
        data-value="{{item.value}}"
        bindtap="onPickTendency"
      >
        <radio value="{{item.value}}" checked="{{tendency === item.value}}" color="#087c6b" />
        <view>
          <view class="option-label">{{item.label}}</view>
          <view class="option-note">{{item.value === 'none' ? '暂不投入也是有效决定' : '现场确认后再完成真实加入'}}</view>
        </view>
      </label>
    </radio-group>
    <view class="hint error-hint" wx:if="{{error}}">{{error}}</view>
    <view class="action-stack">
      <button class="btn-primary confirm-btn" bindtap="onConfirm">确认并生成行动卡</button>
      <button class="btn-secondary" bindtap="onAdjust">返回比较</button>
    </view>
  </block>

  <block wx:else>
    <view class="confirm-box card">
      <view class="confirm-kicker">你的当前结论</view>
      <view class="confirm-text">{{confirmText}}</view>
    </view>

    <view class="screenshot-hint">仅生成主倾向对应的一张卡</view>
    <view class="expectation-card {{actionCard.type === 'none' ? 'none-card' : ''}}" wx:if="{{actionCard}}">
      <view class="expectation-head">
        <view>
          <view class="expectation-kicker">{{actionCard.kicker}}</view>
          <view class="expectation-name">{{actionCard.name}}</view>
        </view>
        <view class="status">{{actionCard.status}}</view>
      </view>
      <view class="score-strip" wx:if="{{actionCard.scoreText}}">{{actionCard.scoreText}}</view>

      <view class="card-section" wx:if="{{actionCard.expectations}}">
        <view class="card-section-title">加入前预期</view>
        <view class="expectation-line" wx:for="{{actionCard.expectations}}" wx:for-item="expectation" wx:key="*this">
          <text class="check">✓</text><text>{{expectation}}</text>
        </view>
      </view>

      <view class="card-section" wx:if="{{actionCard.actions}}">
        <view class="card-section-title">现在这样行动</view>
        <view class="expectation-line" wx:for="{{actionCard.actions}}" wx:for-item="action" wx:key="*this">
          <text class="check">→</text><text>{{action}}</text>
        </view>
      </view>

      <view class="card-section">
        <view class="card-section-title">关键理由</view>
        <view class="expectation-line" wx:for="{{actionCard.reasons}}" wx:for-item="reason" wx:key="*this">
          <text class="check">·</text><text>{{reason}}</text>
        </view>
      </view>

      <view class="card-section" wx:if="{{actionCard.costs}}">
        <view class="card-section-title">你需要接受的代价</view>
        <view class="expectation-line" wx:for="{{actionCard.costs}}" wx:for-item="cost" wx:key="*this">
          <text class="cost-mark">!</text><text>{{cost}}</text>
        </view>
      </view>

      <view class="card-section" wx:if="{{actionCard.unknowns}}">
        <view class="card-section-title">仍然未知</view>
        <view class="expectation-line" wx:for="{{actionCard.unknowns}}" wx:for-item="unknown" wx:key="*this">
          <text class="unknown-mark">?</text><text>{{unknown}}</text>
        </view>
      </view>

      <view class="expectation-reminder">{{actionCard.reminder}}</view>
    </view>

    <block wx:if="{{clubDetail}}">
      <view class="detail-panel">
        <view class="section-title">主倾向社团详情</view>
        <view class="section-copy detail-lead">把简介、活动图片和关键安排放在一起，方便你带到招新现场核对。</view>

        <view class="detail-hero card">
          <view class="detail-hero-top">
            <view>
              <view class="eyebrow">{{clubDetail.categoryLabel}}</view>
              <view class="detail-name">{{clubDetail.name}}</view>
            </view>
            <view class="verify-chip">待现场核实</view>
          </view>
          <view class="detail-tagline">{{clubDetail.tagline}}</view>
          <view class="tag-row">
            <text wx:for="{{clubDetail.tags}}" wx:key="*this" class="chip">{{item}}</text>
          </view>
        </view>

        <view class="section-title soft">活动图片</view>
        <scroll-view class="gallery" scroll-x show-scrollbar="{{false}}">
          <view class="gallery-track">
            <view class="gallery-item" wx:for="{{clubDetail.images}}" wx:key="caption">
              <image wx:if="{{item.src && !item.isPlaceholder}}" class="gallery-image" src="{{item.src}}" mode="aspectFill" />
              <view wx:else class="gallery-placeholder">
                <text class="gallery-placeholder-mark">IMG</text>
                <text class="gallery-placeholder-copy">图片占位</text>
              </view>
              <view class="gallery-caption">{{item.caption}}</view>
            </view>
          </view>
        </scroll-view>

        <view class="section-title soft">时间与参与</view>
        <view class="detail-card card">
          <view class="fact"><text class="fact-label">普通周</text><text>{{clubDetail.normalHours}}</text></view>
          <view class="fact"><text class="fact-label">高峰周</text><text>{{clubDetail.peakHours}}</text></view>
          <view class="fact"><text class="fact-label">常见时段</text><text>{{clubDetail.slotsText}}</text></view>
          <view class="fact"><text class="fact-label">活动频率</text><text>{{clubDetail.frequency}}</text></view>
          <view class="fact"><text class="fact-label">活动形式</text><text>{{clubDetail.modesText}}</text></view>
          <view class="fact"><text class="fact-label">成长收益</text><text>{{clubDetail.benefitsText}}</text></view>
          <view class="fact"><text class="fact-label">考勤弹性</text><text>{{clubDetail.flexibilityText}}；{{clubDetail.attendanceText}}</text></view>
          <view class="fact"><text class="fact-label">投入模式</text><text>{{clubDetail.commitmentText}}</text></view>
        </view>

        <view class="section-title soft">加入条件与成本</view>
        <view class="detail-card card">
          <view class="fact"><text class="fact-label">入门方式</text><text>{{clubDetail.entryText}}</text></view>
          <view class="fact"><text class="fact-label">是否选拔</text><text>{{clubDetail.selectionText}}</text></view>
          <view class="fact"><text class="fact-label">费用估计</text><text>{{clubDetail.costText}}</text></view>
          <view class="fact"><text class="fact-label">器材要求</text><text>{{clubDetail.equipmentText}}</text></view>
          <view class="fact"><text class="fact-label">校外活动</text><text>{{clubDetail.offCampusText}}</text></view>
        </view>
      </view>
    </block>

    <view class="questions card">
      <view class="section-title">{{questionTitle}}</view>
      <view class="section-copy">{{questionLead}}</view>
      <view class="question" wx:for="{{boothQuestions}}" wx:key="question">
        <view class="question-number">{{index + 1}}</view>
        <view class="question-main">
          <view>{{item.question}}</view>
          <view class="question-source">为什么问：{{item.sourceText}}</view>
        </view>
      </view>
    </view>

    <view class="review card">
      <view class="section-title">四周后，用这些标准复盘</view>
      <view class="review-item" wx:for="{{reviewStandards}}" wx:key="*this">
        <view class="review-box"></view>
        <view>{{item}}</view>
      </view>
    </view>

    <view class="evidence-notice">
      <view class="evidence-notice-title">资料边界</view>
      <view>{{evidenceNotice}}</view>
    </view>

    <view class="exit-box">
      <view class="exit-title">真实加入仍在线下完成</view>
      <view class="exit-body">核实后，再通过社团真实招新摊位、官方群聊或报名渠道加入。本工具不会代你报名，也不会保存或同步本次结果。</view>
    </view>
    <view class="actions">
      <button class="btn-primary" bindtap="onAdjust">返回比较</button>
      <button class="btn-secondary" bindtap="onRestart">重新开始</button>
    </view>
  </block>
</view>
