<view class="page">
  <view class="title">社团对照</view>
  <view class="lead">并排比较你勾选的社团。点社团名可看详情。</view>

  <view class="hint" wx:if="{{error}}">{{error}}</view>

  <scroll-view scroll-x class="table-scroll" wx:if="{{!error}}">
    <view class="table">
      <view class="row header">
        <view class="cell label">字段</view>
        <view
          class="cell linkish"
          wx:for="{{columns}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onOpen"
        >{{item.name}}</view>
      </view>
      <view class="row" wx:for="{{rows}}" wx:key="key">
        <view class="cell label">{{item.label}}</view>
        <view class="cell" wx:for="{{item.values}}" wx:for-item="val" wx:for-index="vi" wx:key="vi">{{val}}</view>
      </view>
    </view>
  </scroll-view>

  <button class="btn-primary" bindtap="onQuestions" wx:if="{{!error}}">选择好了，给我提问建议</button>
</view>
