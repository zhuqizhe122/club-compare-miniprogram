<view class="page">
  <view class="title">对照表</view>
  <view class="lead">并排比较你勾选的社团（缺项显示「未提供」）</view>

  <scroll-view scroll-x class="table-scroll">
    <view class="table">
      <view class="row header">
        <view class="cell label">字段</view>
        <view class="cell" wx:for="{{columns}}" wx:key="id">{{item.name}}</view>
      </view>
      <view class="row" wx:for="{{rows}}" wx:key="key">
        <view class="cell label">{{item.label}}</view>
        <view class="cell" wx:for="{{item.values}}" wx:for-item="val" wx:for-index="vi" wx:key="vi">{{val}}</view>
      </view>
    </view>
  </scroll-view>

  <button class="btn-primary" bindtap="onNext">做出倾向选择</button>
</view>
