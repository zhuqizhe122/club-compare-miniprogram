.page {
  padding-top: 52rpx;
}

.hero {
  padding: 32rpx 6rpx 48rpx;
}

.hero-title {
  margin-top: 22rpx;
  font-size: 58rpx;
  line-height: 1.2;
  font-weight: 800;
  letter-spacing: -2rpx;
}

.hero-lead {
  margin-top: 30rpx;
  color: var(--ink-soft);
  font-size: 29rpx;
  line-height: 1.75;
}

.entry-grid {
  margin-top: 42rpx;
}

.entry-card {
  margin-bottom: 18rpx;
  padding: 30rpx;
  border: 1px solid var(--line);
  border-radius: 24rpx;
  background: var(--paper);
  box-shadow: var(--shadow);
}

.assessment-entry {
  color: #fff;
  border-color: var(--brand);
  background: linear-gradient(135deg, #087c6b, #0b4e45);
}

.filter-entry {
  border-color: #9fcfc5;
  background: #edf8f5;
}

.entry-kicker {
  color: var(--brand);
  font-size: 21rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.assessment-entry .entry-kicker,
.assessment-entry .entry-copy {
  color: #cfece5;
}

.entry-title {
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 750;
}

.entry-copy {
  margin-top: 10rpx;
  color: var(--ink-soft);
  font-size: 24rpx;
  line-height: 1.65;
}

.entry-link {
  margin-top: 20rpx;
  color: var(--brand);
  font-size: 25rpx;
  font-weight: 700;
}

.assessment-entry .entry-link {
  color: #fff;
}

.privacy-note {
  margin-top: 18rpx;
  color: #79908b;
  text-align: center;
  font-size: 22rpx;
}

.value-section {
  margin-top: 24rpx;
}

.step {
  display: flex;
  gap: 24rpx;
  padding: 26rpx;
  margin-bottom: 16rpx;
}

.step-number {
  flex: 0 0 68rpx;
  color: var(--brand);
  font-size: 23rpx;
  font-weight: 700;
  padding-top: 4rpx;
}

.step-title {
  font-size: 29rpx;
  font-weight: 700;
}

.step-copy {
  margin-top: 7rpx;
  color: var(--ink-soft);
  font-size: 24rpx;
}

.boundary {
  margin-top: 34rpx;
  padding: 24rpx;
  color: #765222;
  background: var(--warn-bg);
  border: 1px solid #efd8af;
  border-radius: 18rpx;
}

.boundary-title {
  font-size: 26rpx;
  font-weight: 700;
}

.boundary-copy {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.7;
}
