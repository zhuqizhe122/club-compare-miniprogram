.quiz-topline {
  display: flex;
  justify-content: space-between;
  color: #555;
  font-size: 26rpx;
}

.progress-track {
  height: 12rpx;
  margin: 18rpx 0 32rpx;
  overflow: hidden;
  background: #e8e8e8;
  border-radius: 999rpx;
}

.progress-value {
  height: 100%;
  background: #1a1a1a;
  border-radius: 999rpx;
  transition: width 0.2s ease;
}

.question-card {
  padding: 32rpx;
  background: #fff;
  border-radius: 16rpx;
}

.question-number {
  color: #777;
  font-size: 24rpx;
}

.question-text {
  margin: 12rpx 0 28rpx;
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.45;
}

.answer-option {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx;
  margin-top: 16rpx;
  border: 1px solid #dedede;
  border-radius: 12rpx;
  line-height: 1.4;
}

.answer-option.selected {
  color: #fff;
  background: #1a1a1a;
  border-color: #1a1a1a;
}

.answer-dot {
  flex: 0 0 18rpx;
  width: 18rpx;
  height: 18rpx;
  border: 2px solid currentColor;
  border-radius: 50%;
}

.answer-option.selected .answer-dot {
  background: #fff;
  box-shadow: inset 0 0 0 4rpx #1a1a1a;
}

.quiz-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.action-button {
  flex: 1;
  margin: 0;
}
