<view class="page quiz-page">
  <view class="quiz-topline">
    <text>社团倾向小测试</text>
    <text>{{progressText}}</text>
  </view>
  <view class="progress-track">
    <view class="progress-value" style="width: {{progressPercent}}%;"></view>
  </view>

  <view class="question-card">
    <view class="question-number">第 {{currentIndex + 1}} 题</view>
    <view class="question-text">{{currentQuestion.text}}</view>
    <view
      class="answer-option {{selectedOptionId === item.id ? 'selected' : ''}}"
      wx:for="{{currentQuestion.options}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onOptionTap"
    >
      <view class="answer-dot"></view>
      <text>{{item.label}}</text>
    </view>
  </view>

  <view class="hint" wx:if="{{error}}">{{error}}</view>
  <view class="quiz-actions">
    <button class="btn-secondary action-button" wx:if="{{!isFirst}}" bindtap="onPrevious">上一题</button>
    <button class="btn-primary action-button" bindtap="onNext">{{isLast ? '查看结果' : '下一题'}}</button>
  </view>
</view>
