.guard {
  display: flex;
  justify-content: space-between;
  margin-bottom: 26rpx;
  padding: 18rpx 22rpx;
  border-radius: 16rpx;
  color: var(--warn);
  background: var(--warn-bg);
  font-size: 23rpx;
}

.guard.ready {
  color: var(--brand-dark);
  background: var(--brand-light);
}

.selection-card {
  padding: 26rpx;
  margin-bottom: 24rpx;
}

.card-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.order {
  display: flex;
  flex: 0 0 52rpx;
  height: 52rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #fff;
  background: var(--brand);
  font-weight: 800;
}

.identity {
  flex: 1;
}

.club-name {
  font-size: 31rpx;
  font-weight: 750;
}

.category,
.tagline {
  color: var(--ink-soft);
  font-size: 23rpx;
}

.tagline {
  margin-top: 16rpx;
}

.facts {
  margin-top: 20rpx;
  padding: 8rpx 18rpx;
  border-radius: 14rpx;
  background: #f5f8f7;
}

.fact {
  display: flex;
  justify-content: space-between;
  gap: 22rpx;
  padding: 12rpx 0;
  font-size: 23rpx;
}

.fact text:first-child {
  flex: none;
  color: var(--ink-soft);
}

.risk {
  margin-top: 18rpx;
  color: var(--warn);
  font-size: 23rpx;
}

.risk-title {
  display: block;
  margin-bottom: 6rpx;
  font-weight: 700;
}

.remove {
  margin: 20rpx 0 0;
  color: var(--danger);
  background: #fff3f1;
  font-size: 24rpx;
  line-height: 70rpx;
}

.empty {
  padding: 36rpx 28rpx;
  margin-bottom: 24rpx;
}
