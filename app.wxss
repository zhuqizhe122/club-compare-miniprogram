page {
  background: #f7f7f7;
  color: #1a1a1a;
  font-size: 28rpx;
  line-height: 1.5;
}

.page {
  padding: 40rpx 32rpx 80rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

.btn-primary {
  margin-top: 40rpx;
  background: #1a1a1a;
  color: #fff;
  border-radius: 8rpx;
  font-size: 30rpx;
}

.btn-primary[disabled] {
  background: #bbb;
  color: #fff;
}

.btn-secondary {
  margin-top: 24rpx;
  background: #fff;
  color: #1a1a1a;
  border: 1px solid #ccc;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.hint {
  color: #666;
  font-size: 24rpx;
  margin-top: 16rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.lead {
  color: #444;
  margin-bottom: 24rpx;
}
