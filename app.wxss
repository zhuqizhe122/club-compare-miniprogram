page {
  --ink: #142f2b;
  --ink-soft: #58706c;
  --brand: #087c6b;
  --brand-dark: #0b4e45;
  --brand-light: #dff2ed;
  --mint: #e8f4f0;
  --paper: #ffffff;
  --canvas: #f2f5f3;
  --line: #d8e2df;
  --line-strong: #b9cbc6;
  --warn: #9b5b16;
  --warn-bg: #fff4df;
  --danger: #a33d35;
  --shadow: 0 12rpx 36rpx rgba(20, 47, 43, 0.08);
  background: var(--canvas);
  color: var(--ink);
  font-size: 28rpx;
  line-height: 1.55;
}

.page {
  padding: 36rpx 30rpx calc(88rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  min-height: 100vh;
}

.page-with-tray {
  padding-bottom: calc(230rpx + env(safe-area-inset-bottom));
}

.btn-primary {
  margin-top: 32rpx;
  background: var(--brand);
  color: #fff;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 92rpx;
  min-height: 92rpx;
  box-shadow: 0 12rpx 28rpx rgba(8, 127, 112, 0.18);
}

button::after {
  border: 0;
}

.btn-primary[disabled] {
  background: #a9bdb8;
  box-shadow: none;
}

.btn-secondary {
  margin-top: 20rpx;
  background: var(--paper);
  color: var(--brand-dark);
  border: 1px solid var(--line);
  border-radius: 18rpx;
  font-size: 28rpx;
  min-height: 84rpx;
}

.btn-ghost {
  margin: 0;
  padding: 0 24rpx;
  color: var(--brand);
  background: transparent;
  font-size: 26rpx;
  line-height: 72rpx;
}

.btn-inline {
  display: inline-flex;
  width: auto;
  margin: 0;
}

.hint {
  color: var(--ink-soft);
  font-size: 24rpx;
  margin-top: 14rpx;
}

.title {
  font-size: 46rpx;
  line-height: 1.25;
  font-weight: 700;
  letter-spacing: -1rpx;
  margin-bottom: 14rpx;
}

.lead {
  color: var(--ink-soft);
  margin-bottom: 28rpx;
}

.card {
  background: var(--paper);
  border: 1px solid var(--line);
  border-radius: 24rpx;
  box-shadow: var(--shadow);
}

.eyebrow {
  color: var(--brand);
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}

.status {
  display: inline-flex;
  align-items: center;
  color: var(--warn);
  background: #fff7e9;
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  font-size: 21rpx;
}

.text-button {
  display: inline-block;
  color: var(--brand);
  font-size: 26rpx;
  padding: 18rpx 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.section-copy {
  color: var(--ink-soft);
  font-size: 25rpx;
}

.divider {
  height: 1px;
  background: var(--line);
}

.chip {
  display: inline-flex;
  align-items: center;
  margin: 0 10rpx 10rpx 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: var(--brand-dark);
  background: var(--mint);
  font-size: 22rpx;
}

.mono {
  font-variant-numeric: tabular-nums;
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
