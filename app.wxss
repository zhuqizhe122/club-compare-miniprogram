page {
  --ink: #153c36;
  --ink-soft: #52706b;
  --brand: #087f70;
  --brand-dark: #0d5148;
  --mint: #e4f3ef;
  --paper: #ffffff;
  --canvas: #f3f7f5;
  --line: #d9e6e2;
  --warn: #9a5d16;
  background: var(--canvas);
  color: var(--ink);
  font-size: 28rpx;
  line-height: 1.55;
}

.page {
  padding: 36rpx 30rpx 88rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

.btn-primary {
  margin-top: 32rpx;
  background: var(--brand);
  color: #fff;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 92rpx;
  min-height: 92rpx;
  box-shadow: 0 12rpx 28rpx rgba(8, 127, 112, 0.18);
}

button::after {
  border: 0;
}

.btn-primary[disabled] {
  background: #a9bdb8;
  box-shadow: none;
}

.btn-secondary {
  margin-top: 20rpx;
  background: var(--paper);
  color: var(--brand-dark);
  border: 1px solid var(--line);
  border-radius: 18rpx;
  font-size: 28rpx;
  min-height: 84rpx;
}

.hint {
  color: var(--ink-soft);
  font-size: 24rpx;
  margin-top: 14rpx;
}

.title {
  font-size: 46rpx;
  line-height: 1.25;
  font-weight: 700;
  letter-spacing: -1rpx;
  margin-bottom: 14rpx;
}

.lead {
  color: var(--ink-soft);
  margin-bottom: 28rpx;
}

.card {
  background: var(--paper);
  border: 1px solid var(--line);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 26rpx rgba(21, 60, 54, 0.06);
}

.eyebrow {
  color: var(--brand);
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}

.status {
  display: inline-flex;
  align-items: center;
  color: var(--warn);
  background: #fff7e9;
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  font-size: 21rpx;
}

.text-button {
  display: inline-block;
  color: var(--brand);
  font-size: 26rpx;
  padding: 18rpx 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}
